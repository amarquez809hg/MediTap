# Copy to docker/.env on a cloud VM and replace placeholders.
# See docs/deploy-gcp-vm.md

# VM external IP or DNS hostname only (no scheme, no port)
MEDITAP_PUBLIC_HOST=34.56.78.90

# Use https when you copy docker-compose.override.public-https.example.yml → docker-compose.override.yml
# (required for Keycloak in the browser on a public IP — see docs/deploy-gcp-vm.md §0)
MEDITAP_PUBLIC_SCHEME=https

# Django CORS — must match how users open the SPA (scheme + host + port)
MEDITAP_CORS_EXTRA_ORIGINS=https://34.56.78.90:8100

# Staff sign-in (Tab 13/14): paste from Keycloak → Clients → meditap-elevate → Credentials
# KEYCLOAK_ELEVATE_CLIENT_SECRET=

# Optional Epic sandbox (backend only)
# EPIC_INTEGRATION_ENABLED=1
# EPIC_REDIRECT_URI=http://34.56.78.90:8100/epic-callback
