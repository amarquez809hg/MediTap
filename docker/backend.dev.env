DEBUG=True
SECRET_KEY=dev-secret
DATABASE_URL=postgres://meditap_user:meditap_pass@db:5432/meditap
ALLOWED_HOSTS=*
KEYCLOAK_JWKS_URL=http://auth:8080/realms/meditap/protocol/openid-connect/certs
KEYCLOAK_ALLOWED_ISSUERS=http://localhost:8081/realms/meditap,http://127.0.0.1:8081/realms/meditap,http://auth:8080/realms/meditap
KEYCLOAK_EXPECTED_AZP=meditap-spa
KEYCLOAK_TRUST_ISSUER_SUFFIX=true
KEYCLOAK_ISSUER_SUFFIX=/realms/meditap

# --- Staff sign-in (Tab14): paste real client secret; restart backend ---
# docker-compose.yml already sets KEYCLOAK_TOKEN_URL + KEYCLOAK_ELEVATE_CLIENT_ID for the backend service.
# Keycloak → Clients → meditap-elevate → Credentials → Client secret (copy or Regenerate).
# Dev default is provisioned by docker/keycloak-http-dev.configure.sh; keep this value in sync if you change either side.
# ↓↓↓ Replace the placeholder with your actual secret (one line, no quotes) ↓↓↓
KEYCLOAK_ELEVATE_CLIENT_SECRET=rm3HOighuuYUXo1vi4sIXdNz53kzIhIx
MEDITAP_RECORD_EDITOR_ROLE=meditap-record-editor

# --- Epic FHIR sandbox (optional): set EPIC_INTEGRATION_ENABLED=1 and fill URLs from fhir.epic.com ---
# EPIC_INTEGRATION_ENABLED=1
# EPIC_SANDBOX=true
# EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
# EPIC_AUTHORIZE_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize
# EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token
# EPIC_CLIENT_ID=your-nonprod-client-id
# EPIC_CLIENT_SECRET=   # omit for public clients; many Epic apps are confidential
# EPIC_REDIRECT_URI=http://localhost:8100/epic-callback
# EPIC_DEFAULT_SCOPE=openid fhirUser launch/patient patient/Patient.read patient/Observation.read

# Optional dev: Keycloak Admin API email→username when staff is not the same session as patient.
# Same-session email sign-in uses the patient JWT (no admin password). Uncomment if needed:
# KEYCLOAK_DEV_MASTER_ADMIN_PASSWORD=admin
