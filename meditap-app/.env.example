# Copy to .env.local for local `npm run dev` (optional; defaults match docker-compose frontend env)
# Use "auto" so Keycloak is at same hostname as the app, port 8081 (LAN / phone friendly).
VITE_KEYCLOAK_URL=auto
VITE_KEYCLOAK_REALM=meditap
VITE_KEYCLOAK_CLIENT_ID=meditap-spa
# Realm role required to edit Tab14 patient intake (staff). Create in Keycloak → Realm roles.
VITE_KEYCLOAK_ROLE_RECORD_EDITOR=meditap-record-editor
VITE_KEYCLOAK_REDIRECT_PATH=/tab3
# Optional: Epic on FHIR developer portal URL (Tab 3 “Open Epic developer portal” link).
# VITE_EPIC_DEVELOPER_PORTAL_URL=https://fhir.epic.com/
# Cloud VM / reverse proxy: override API base (default is same hostname as SPA, port 8080).
# VITE_API_BASE=http://34.56.78.90:8080
